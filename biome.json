{
  "$schema": "https://biomejs.dev/schemas/2.3.12/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": [["react", "react-native"], ":BLANK_LINE:", ":PACKAGE:", ":BLANK_LINE:", ":PATH:"]
          }
        }
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "paths": {
              "features/uniswap-v3/data": "Import from 'features/uniswap-v3' (façade) instead of internals.",
              "features/uniswap-v3/data/uniswap-v3.mapper": "Import from 'features/uniswap-v3' (façade) instead of internals.",
              "features/uniswap-v3/domain": "Import from 'features/uniswap-v3' (façade) instead of internals.",
              "features/uniswap-v3/domain/uniswap-v3.vm": "Import from 'features/uniswap-v3' (façade) instead of internals.",
              "features/uniswap-v3/application": "Import from 'features/uniswap-v3' (façade) instead of internals.",
              "features/uniswap-v3/presentation": "Import from 'features/uniswap-v3' (façade) instead of internals.",
              "features/uniswap-v3/presentation/components/ListBody": "Import from 'features/uniswap-v3' (façade) instead of internals.",
              "features/uniswap-v3/presentation/components/DetailBody": "Import from 'features/uniswap-v3' (façade) instead of internals.",
              "features/uniswap-v3/presentation/components/Strip": "Import from 'features/uniswap-v3' (façade) instead of internals.",
              "features/uniswap-v3/presentation/components/PriceRangeBar": "Import from 'features/uniswap-v3' (façade) instead of internals.",
              "features/uniswap-v3/plugin": "Import from 'features/uniswap-v3' (façade) instead of internals."
            }
          }
        }
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 145
  },
  "files": {
    "includes": [
      "**",
      "!**/node_modules",
      "!**/.expo",
      "!**/dist",
      "!**/.turbo",
      "!apps/subgraphs/**/generated",
      "!apps/server/**/gql",
      "!apps/server/openapi",
      "!apps/server/src/features/token-prices/data/tokens-data.generated.ts",
      "!apps/mobile/src/core/tokens-data/generated.d.ts",
      "!apps/tokens-data/generated"
    ]
  },
  "overrides": [
    {
      "includes": ["apps/subgraphs/**/src/**", "apps/subgraphs/**/tests/**"],
      "linter": {
        "rules": {
          "style": {
            "useConst": "off",
            "useImportType": "off",
            "useTemplate": "off"
          },
          "suspicious": {
            "noDoubleEquals": "off",
            "noShadowRestrictedNames": "off"
          },
          "correctness": {
            "noUnusedImports": "off"
          }
        }
      },
      "assist": {
        "actions": {
          "source": {
            "organizeImports": "off"
          }
        }
      }
    }
  ],
  "javascript": {
    "parser": {
      "unsafeParameterDecoratorsEnabled": true
    }
  }
}
