{
  "$schema": "https://biomejs.dev/schemas/2.3.12/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": [["react", "react-native"], ":BLANK_LINE:", ":PACKAGE:", ":BLANK_LINE:", ":PATH:"]
          }
        }
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 145
  },
  "files": {
    "includes": [
      "**",
      "!**/node_modules",
      "!**/.expo",
      "!**/dist",
      "!**/.turbo",
      "!apps/subgraphs/**/generated",
      "!apps/server/**/gql",
      "!apps/server/openapi",
      "!apps/server/src/features/token-prices/data/tokens-data.generated.ts",
      "!apps/mobile/src/core/tokens-data/generated.d.ts",
      "!apps/tokens-data/generated",
      "!apps/landing/_site",
      "!apps/landing/src/assets/js/hero.bundle.js",
      "!apps/server/src/static/htmx.min.js",
      "!**/.impeccable/**",
      "!.claude/skills/**",
      "!.agents/skills/**",
      "!skills-lock.json"
    ]
  },
  "overrides": [
    {
      "includes": ["apps/server/src/presentation/web/styles/**/*.css"],
      "linter": {
        "rules": {
          "correctness": {
            "noInvalidPositionAtImportRule": "off"
          }
        }
      }
    },
    {
      "includes": ["apps/subgraphs/**/src/**", "apps/subgraphs/**/tests/**"],
      "linter": {
        "rules": {
          "style": {
            "useConst": "off",
            "useImportType": "off",
            "useTemplate": "off"
          },
          "suspicious": {
            "noDoubleEquals": "off",
            "noShadowRestrictedNames": "off"
          },
          "correctness": {
            "noUnusedImports": "off"
          }
        }
      },
      "assist": {
        "actions": {
          "source": {
            "organizeImports": "off"
          }
        }
      }
    }
  ],
  "css": {
    "parser": {
      "tailwindDirectives": true
    },
    "linter": {
      "enabled": true
    }
  },
  "javascript": {
    "parser": {
      "unsafeParameterDecoratorsEnabled": true
    }
  }
}
