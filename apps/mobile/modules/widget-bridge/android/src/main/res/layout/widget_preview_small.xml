<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="vertical"
  android:background="@drawable/widget_bg_dark"
  android:padding="16dp">

  <TextView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:text="ETH/USDC"
    android:textColor="#FFFFFF"
    android:textSize="20sp"
    android:textStyle="bold"
    android:singleLine="true"
    android:ellipsize="end"/>

  <Space
    android:layout_width="match_parent"
    android:layout_height="12dp"/>

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical">

    <LinearLayout
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:orientation="horizontal"
      android:gravity="center_vertical"
      android:paddingStart="8dp"
      android:paddingEnd="8dp"
      android:paddingTop="2dp"
      android:paddingBottom="2dp"
      android:background="@drawable/widget_preview_tag_bg">
      <View
        android:layout_width="6dp"
        android:layout_height="6dp"
        android:background="@drawable/widget_preview_dot_chain"/>
      <Space
        android:layout_width="4dp"
        android:layout_height="match_parent"/>
      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Base"
        android:textColor="#B3FFFFFF"
        android:textSize="11sp"/>
    </LinearLayout>

    <Space
      android:layout_width="4dp"
      android:layout_height="match_parent"/>

    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="0.30%"
      android:textColor="#B3FFFFFF"
      android:textSize="11sp"
      android:paddingStart="8dp"
      android:paddingEnd="8dp"
      android:paddingTop="2dp"
      android:paddingBottom="2dp"
      android:background="@drawable/widget_preview_tag_bg"/>
  </LinearLayout>

  <Space
    android:layout_width="match_parent"
    android:layout_height="8dp"/>

  <View
    android:layout_width="match_parent"
    android:layout_height="8dp"
    android:background="@drawable/widget_preview_track"/>

  <Space
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="1"/>

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal">
    <TextView
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:text="Value"
      android:textColor="#B3FFFFFF"
      android:textSize="12sp"/>
    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="1.23 / 0.5"
      android:textColor="#FFFFFF"
      android:textSize="14sp"
      android:textStyle="bold"/>
  </LinearLayout>

  <Space
    android:layout_width="match_parent"
    android:layout_height="6dp"/>

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal">
    <TextView
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:text="Fees"
      android:textColor="#B3FFFFFF"
      android:textSize="12sp"/>
    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="+0.01 / +0.02"
      android:textColor="#FF3D6E"
      android:textSize="13sp"
      android:textStyle="bold"/>
  </LinearLayout>
</LinearLayout>
