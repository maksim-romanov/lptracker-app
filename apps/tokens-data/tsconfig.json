{
  "extends": "@depthly/typescript-config/base.json",
  "compilerOptions": {
    "types": ["bun", "reflect-metadata"],
    "strict": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": "src",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "paths": {
      "features/*": ["features/*"],
      "shared/*": ["shared/*"]
    }
  },
  "exclude": ["codegen.ts"]
}
