<section id="cta" class="cta">
  <div class="inner">
    <p class="eyebrow">{{ site.cta.eyebrow }}</p>
    <h2>{{ site.cta.title }}</h2>
    <a class="button"
       href="{{ site.waitlistUrl }}"
       data-popup-tally="{{ site.waitlistFormId }}"
       target="_blank"
       rel="noopener noreferrer">
      {{ site.cta.button }}
    </a>
    <p class="note">{{ site.cta.note }}</p>
  </div>
</section>
