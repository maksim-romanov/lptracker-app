{
  "openapi": "3.1.0",
  "info": {
    "title": "depthly Gateway API",
    "description": "Protocol-agnostic gateway API for DeFi position aggregation across wallets, chains, and protocols",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/api/v1",
      "description": "Gateway API v1"
    }
  ],
  "tags": [
    {
      "name": "Positions",
      "description": "Multi-wallet, multi-chain, multi-protocol position endpoints"
    },
    {
      "name": "Catalog",
      "description": "Networks and protocols metadata"
    }
  ],
  "paths": {
    "/catalog": {
      "get": {
        "operationId": "getCatalog",
        "tags": [
          "Catalog"
        ],
        "summary": "Networks and protocols catalog",
        "description": "Authoritative list of networks the backend knows about and protocols it supports.",
        "responses": {
          "200": {
            "description": "Catalog",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Catalog"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/positions": {
      "get": {
        "operationId": "getPositions",
        "tags": [
          "Positions"
        ],
        "summary": "List positions across wallets, chains, and protocols",
        "description": "Returns all positions across the requested scope, sorted by updatedAt desc. Each chain×protocol source is capped server-side. Effective scope is the intersection of each wallet's chains and each protocol's supported chains.",
        "responses": {
          "200": {
            "description": "Merged list of positions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Position"
                      }
                    },
                    "tokens": {
                      "$ref": "#/components/schemas/TokensMap"
                    }
                  },
                  "required": [
                    "data",
                    "tokens"
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "in": "query",
            "name": "wallets",
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^0x[a-fA-F0-9]{40}:\\d+(?:,\\d+)*$"
              },
              "minItems": 1
            },
            "required": true
          },
          {
            "in": "query",
            "name": "protocols",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "status",
            "schema": {
              "enum": [
                "open",
                "closed",
                "all"
              ],
              "default": "open"
            }
          }
        ]
      }
    },
    "/positions/{ref}": {
      "get": {
        "operationId": "getPositions:ref",
        "tags": [
          "Positions"
        ],
        "summary": "Get a single position by ref",
        "description": "Returns the full detail for one position. `ref` is opaque — obtain from list responses.",
        "responses": {
          "200": {
            "description": "Position detail",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/Position"
                    },
                    "tokens": {
                      "$ref": "#/components/schemas/TokensMap"
                    }
                  },
                  "required": [
                    "data",
                    "tokens"
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Position not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "in": "path",
            "name": "ref",
            "schema": {
              "type": "string",
              "pattern": "^[a-z0-9-]+:\\d+:[A-Za-z0-9_-]+$"
            },
            "required": true
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Network": {
        "type": "object",
        "properties": {
          "chainId": {
            "type": "number"
          },
          "slug": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "shortName": {
            "type": "string"
          },
          "nativeCurrency": {
            "type": "object",
            "properties": {
              "symbol": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "decimals": {
                "type": "number"
              }
            },
            "required": [
              "symbol",
              "name",
              "decimals"
            ]
          },
          "iconUrl": {
            "type": "string"
          },
          "explorerUrl": {
            "type": "string"
          }
        },
        "required": [
          "chainId",
          "slug",
          "name",
          "shortName",
          "nativeCurrency",
          "iconUrl",
          "explorerUrl"
        ]
      },
      "Protocol": {
        "type": "object",
        "properties": {
          "slug": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "supportedChainIds": {
            "type": "array",
            "items": {
              "type": "number"
            }
          },
          "capabilities": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "extensionVersion": {
            "type": "string"
          }
        },
        "required": [
          "slug",
          "name",
          "version",
          "supportedChainIds",
          "capabilities",
          "extensionVersion"
        ]
      },
      "Catalog": {
        "type": "object",
        "properties": {
          "networks": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Network"
            }
          },
          "protocols": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Protocol"
            }
          }
        },
        "required": [
          "networks",
          "protocols"
        ]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              },
              "field": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "requestId": {
                "type": "string"
              }
            },
            "required": [
              "code",
              "message",
              "field"
            ]
          }
        },
        "required": [
          "error"
        ]
      },
      "PositionContainer": {
        "type": "object",
        "properties": {
          "kind": {
            "type": "string"
          },
          "ref": {
            "type": "string"
          },
          "label": {
            "type": "string"
          }
        },
        "required": [
          "kind",
          "ref",
          "label"
        ]
      },
      "TokenRef": {
        "type": "string",
        "pattern": "^\\d+:0x[a-f0-9]{40}$"
      },
      "TokenAmount": {
        "type": "object",
        "properties": {
          "raw": {
            "type": "string",
            "pattern": "^-?\\d+$"
          },
          "decimals": {
            "type": "number"
          },
          "formatted": {
            "type": "string"
          },
          "tokenRef": {
            "$ref": "#/components/schemas/TokenRef"
          }
        },
        "required": [
          "raw",
          "decimals",
          "formatted",
          "tokenRef"
        ]
      },
      "PositionToken": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string"
          },
          "tokenRef": {
            "$ref": "#/components/schemas/TokenRef"
          },
          "balance": {
            "$ref": "#/components/schemas/TokenAmount"
          }
        },
        "required": [
          "role",
          "tokenRef",
          "balance"
        ]
      },
      "PositionStatus": {
        "type": "object",
        "properties": {
          "state": {
            "type": "string"
          },
          "stateDetail": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "required": [
          "state",
          "stateDetail"
        ]
      },
      "UniswapV3Extension": {
        "type": "object",
        "properties": {
          "type": {
            "const": "uniswap-v3"
          },
          "version": {
            "const": 1
          },
          "tickLower": {
            "type": "number"
          },
          "tickUpper": {
            "type": "number"
          },
          "liquidity": {
            "type": "string"
          },
          "feeTier": {
            "type": "number"
          },
          "feeTierLabel": {
            "type": "string"
          },
          "nftTokenId": {
            "type": "string"
          },
          "pool": {
            "type": "object",
            "properties": {
              "address": {
                "type": "string"
              },
              "currentTick": {
                "type": "number"
              },
              "sqrtPriceX96": {
                "type": "string"
              },
              "tickSpacing": {
                "type": "number"
              }
            },
            "required": [
              "address",
              "currentTick",
              "sqrtPriceX96"
            ]
          }
        },
        "required": [
          "type",
          "version",
          "tickLower",
          "tickUpper",
          "liquidity",
          "feeTier",
          "feeTierLabel",
          "nftTokenId",
          "pool"
        ]
      },
      "UnknownExtension": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "version": {
            "type": "number"
          }
        },
        "required": [
          "type",
          "version"
        ]
      },
      "Position": {
        "type": "object",
        "properties": {
          "ref": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "chainId": {
            "type": "number"
          },
          "protocol": {
            "type": "string"
          },
          "protocolVersion": {
            "type": "string"
          },
          "container": {
            "$ref": "#/components/schemas/PositionContainer"
          },
          "tokens": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PositionToken"
            }
          },
          "status": {
            "$ref": "#/components/schemas/PositionStatus"
          },
          "createdAt": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "updatedAt": {
            "type": "string"
          },
          "extension": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/UniswapV3Extension"
              },
              {
                "$ref": "#/components/schemas/UnknownExtension"
              }
            ]
          }
        },
        "required": [
          "ref",
          "address",
          "chainId",
          "protocol",
          "container",
          "tokens",
          "status",
          "createdAt",
          "updatedAt",
          "extension"
        ]
      },
      "TokenMeta": {
        "type": "object",
        "properties": {
          "symbol": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "decimals": {
            "type": "number"
          },
          "iconUrl": {
            "type": "string"
          },
          "displayDecimals": {
            "type": "number"
          }
        },
        "required": [
          "symbol",
          "decimals",
          "iconUrl"
        ]
      },
      "TokensMap": {
        "type": "object",
        "propertyNames": {
          "$ref": "#/components/schemas/TokenRef"
        },
        "additionalProperties": {
          "$ref": "#/components/schemas/TokenMeta"
        }
      }
    }
  }
}