      "Read(./apps/server/openapi/**)",
      "Read(./apps/mobile/src/**/generated/**)",
      "Read(./apps/subgraphs/*/generated/**)",
      "Read(./apps/subgraphs/*/build/**)"
    ]
  },
  "enabledPlugins": {
